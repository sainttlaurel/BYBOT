# Discord (required)
DISCORD_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_text_channel_id_here

# Multi-Channel Keyword Routing (Option B - Optional)
# Route posts to specific channels if they contain matching keywords (case-insensitive).
# Underscores in keys are treated as spaces (e.g., maintenance_alert -> "maintenance alert").
# If multiple keywords match a post, it will be forwarded to all matching channels.
# Falls back to DISCORD_CHANNEL_ID if no keywords match or routed channels are unreachable.
#DISCORD_ROUTE_maintenance_alert=1514161795651338402
#DISCORD_ROUTE_event=1514161881768788079
#DISCORD_ROUTE_patch_notes=1514162058374021170
#DISCORD_ROUTE_was_live=1514162887168626828          # → #promotion-for-streamer (matches "was live" in shared livestream posts)

# Custom Embed Colors per Route (optional)
# Set custom colors for embeds based on routing keywords
# Colors can be in hex format (#FF0000), hex with 0x prefix (0xFF0000), or integer (16711680)
# Keywords must match the routing keywords defined above (e.g., maintenance_alert, event, etc.)
#DISCORD_ROUTE_COLOR_maintenance_alert=#FF0000       # Red for urgent maintenance
#DISCORD_ROUTE_COLOR_event=#00FF00                   # Green for events
#DISCORD_ROUTE_COLOR_patch_notes=#3B88C3            # Blue for updates
# Note: Live stream posts always use red (0xFF0000) regardless of color config

# Discord (optional)
# Guild ID for instant slash-command sync during development
DISCORD_GUILD_ID=
# Role to ping when a new Facebook post is forwarded (leave blank to disable)
DISCORD_PING_ROLE_ID=
# Dedicated channel for streamer live stream announcements (leave blank to route with keyword logic)
DISCORD_STREAMER_CHANNEL_ID=
# Dedicated channel for security reminders and warnings
DISCORD_SECURITY_CHANNEL_ID=1514162841899368519
# Enable periodic security reminder broadcasts (true/false)
SECURITY_REMINDER_ENABLED=false
# Interval in seconds between security reminder messages
SECURITY_REMINDER_INTERVAL=3600
# Ping @everyone when reminders are sent (true/false)
SECURITY_REMINDER_PING_EVERYONE=false

# Post Filtering (optional)
# Enable author filtering to only forward posts from specific Facebook users
FILTER_BY_AUTHOR=false
# Comma-separated list of Facebook author names to whitelist (exact match, case-sensitive)
# Example: ALLOWED_AUTHORS=Ran BY online GS,BY RAN ONLINE Official,Admin Name
ALLOWED_AUTHORS=

# Facebook (required)
# Comma-separated list of Facebook group/page URLs to monitor
FACEBOOK_SOURCES=https://www.facebook.com/groups/your_group_slug,https://www.facebook.com/your_page_slug
# Fallback (legacy option - only used if FACEBOOK_SOURCES is not set)
FACEBOOK_GROUP_URL=https://www.facebook.com/groups/your_group_slug

# Scheduler
CHECK_INTERVAL=300

# First run: record visible posts in DB without posting to Discord (true/false)
SEED_ON_FIRST_RUN=true

# Paths (relative paths resolve from the BY-BOTS folder)
DATABASE_PATH=database.db

# Logging rotation (optional)
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# Web Dashboard (optional)
# Configuration for the web dashboard server
#DASHBOARD_HOST=127.0.0.1
#DASHBOARD_PORT=5000
#DASHBOARD_SECRET_KEY=bybots-dashboard-secret-change-me-for-production

# Docker (optional)
# When using docker-compose, data is stored in ./data/
#DATABASE_PATH=data/database.db

# Facebook scraper (optional)
# Route Playwright traffic through an HTTP/SOCKS proxy
#SCRAPER_PROXY=http://127.0.0.1:8080
#SCRAPER_PROXY_USERNAME=
#SCRAPER_PROXY_PASSWORD=
# Persist Facebook session cookies to reduce login walls (true/false)
#FACEBOOK_COOKIES_ENABLED=true
#FACEBOOK_COOKIES_PATH=cookies/facebook_cookies.json
# Rotate user-agent on each browser launch (true/false)
#SCRAPER_ROTATE_USER_AGENT=true
# Custom user-agent pool (pipe-separated — commas appear inside UA strings)
#SCRAPER_USER_AGENTS=Mozilla/5.0 (Windows NT 10.0; Win64; x64)|Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)

# Webhooks (optional)
# Comma-separated HTTP endpoints that receive JSON post payloads
#WEBHOOK_URLS=https://example.com/hooks/bybots,https://example.com/hooks/backup
# Enable webhook delivery (defaults to true when WEBHOOK_URLS is set)
#WEBHOOK_ENABLED=true
# Skip Discord channel posting and deliver via webhooks only (true/false)
#WEBHOOK_ONLY=false
# Request timeout in seconds
#WEBHOOK_TIMEOUT=30
